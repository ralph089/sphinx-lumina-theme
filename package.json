{
  "name": "sphinx-lumina-theme",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-assets.js",
    "dev": "node scripts/build-assets.js --watch",
    "prepare": "husky",
    "record-demo": "uv run python scripts/record-demo.py"
  },
  "lint-staged": {
    "*.py": [
      "uv run ruff format",
      "uv run ruff check --fix"
    ],
    "*.html": "uv run djlint --reformat"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@tailwindcss/cli": "^4.0",
    "alpinejs": "^3.15",
    "esbuild": "^0.28",
    "husky": "9.1.7",
    "jsdoc": "^4.0",
    "lint-staged": "16.4.0",
    "lucide-static": "1.8.0",
    "tailwindcss": "^4.0"
  },
  "dependencies": {
    "dompurify": "3.3.3"
  }
}
